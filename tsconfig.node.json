{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "composite": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "electron"],
    "outDir": "out"
  },
  "include": [
    "src/main.ts",
    "src/preload.ts",
    "electron.vite.config.ts"
  ]
}
